# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/blogger

# Set to "true" to enable SSL (e.g., when using a managed Postgres host)
# DATABASE_SSL=true

# Anthropic API key — powers cluster generation, SERP analysis, and
# blog-post generation. Without it the AI features are disabled.
# ANTHROPIC_API_KEY=sk-ant-...

# Pexels API key — supplies hero/body images for generated posts.
# PEXELS_API_KEY=...

# Resend (transactional email). If unset, email sends become no-ops and
# password reset / verification emails silently skip.
# RESEND_API_KEY=re_xxx
# RESEND_FROM=blogger <noreply@example.com>

# Local/test only: capture outbound email into the sent_emails table
# instead of calling Resend, so the Playwright suite can assert on email.
# Never set in production.
# EMAIL_CAPTURE=1

# Local/test only: show a one-click "log in as any user" panel on /login
# for fast manual testing. Bypasses passwords — NEVER set in production.
# DEV_LOGIN=1

# Public base URL for absolute links inside transactional emails (verify,
# password reset). Set this in any environment that sends real emails.
# Falls back to the request's host header when unset.
# APP_URL=https://your-domain.example

# Canonical public URL used for metadataBase / canonical links.
# CANONICAL_URL=https://your-domain.example
